# 이 파일을 복사해 .env.local 로 저장하세요. (Git에 올리지 않음)
# Firebase 콘솔 → 프로젝트 설정 → 일반 → 내 앱 → SDK 설정
# projectId 는 "contrymouse-xxxx" 형태입니다. *.firebasestorage.app 가 아닙니다.

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=contrymouse-xxxx.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=contrymouse-xxxx
NEXT_PUBLIC_FIREBASE_APP_ID=

# GitHub 사용자명 — /admin 접근 허용 계정 (본인만)
NEXT_PUBLIC_ADMIN_GITHUB_LOGIN=wonhwo

# ── 배포 시 (Vercel) ─────────────────────────────────────
# 1. 위 변수를 Vercel → Settings → Environment Variables 에 동일하게 등록
# 2. .env.local / Client Secret 은 절대 GitHub 저장소에 커밋하지 않음
# 3. GitHub OAuth Client Secret 은 Firebase 콘솔에만 보관
# 4. Firebase → Authentication → Authorized domains 에 배포 도메인 추가
# 5. Firebase → Authentication → Settings → Authorized domains 에 localhost 제거(선택, 배포만 쓸 때)

# ── Firestore (노트 글쓰기) ─────────────────────────────
# 1. Firestore Database 생성 (production 모드)
# 2. 규칙 탭에 firestore.rules 내용 게시
# 3. /admin/notes → 「UID 복사」
# 4. Firestore → 컬렉션 admins → 문서 ID에 UID 붙여넣기(자동 ID X), 필드 role: "admin"
# 5. 규칙 탭에 firestore.rules 내용 게시 후 /admin/notes 에서 「권한 다시 확인」
# 6. /admin/notes → 「기존 노트 가져오기」(선택)
# 7. /guestbook 방명록 + /admin/guestbook 승인 (규칙에 guestbook 컬렉션 포함)
#    게임·플레이 로그는 src/data/*.js + public/assets 에서 코드로 관리
