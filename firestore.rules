rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    match /notes/{slug} {
      allow read: if isAdmin();
      allow read: if resource != null && resource.data.published == true;
      allow create, update, delete: if isAdmin();
    }

    match /guestbook/{id} {
      allow read: if isAdmin();
      allow read: if resource != null && resource.data.approved == true;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.approved == false
        && request.resource.data.githubLogin is string
        && request.resource.data.name is string
        && request.resource.data.message is string
        && request.resource.data.githubLogin.size() > 0
        && request.resource.data.githubLogin.size() <= 39
        && request.resource.data.name == request.resource.data.githubLogin
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 500;
      allow update, delete: if isAdmin();
    }
  }
}
